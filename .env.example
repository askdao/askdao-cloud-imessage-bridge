# === iMessage Bridge — Environment Variables ===

# WebSocket server port (Python clients connect here)
BRIDGE_PORT=3002

# Auth token for Python client connections (empty = no auth)
BRIDGE_TOKEN=

# BlueBubbles server URL (must be running on macOS with iMessage)
BLUEBUBBLES_URL=http://localhost:1234

# BlueBubbles server password (required)
BLUEBUBBLES_PASSWORD=
